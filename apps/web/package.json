{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "prebuild": "cd ../../packages/types && bun run build && cd ../template-generator && bun run build",
    "build": "vite build",
    "dev": "vite dev --port 3333",
