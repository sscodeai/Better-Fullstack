{
  "name": "@better-fullstack/template-generator",
  "version": "1.6.3",
  "description": "Virtual file system generator for Better-Fullstack templates - works in browsers and Node.js",
  "keywords": [
    "better-fullstack",
    "cli",
    "template-generator",
    "typescript",
    "virtual-fs"
  ],
  "homepage": "https://better-fullstack-web.vercel.app/",
  "license": "MIT",
  "author": "Marve10s",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marve10s/Better-Fullstack.git",
    "directory": "packages/template-generator"
  },
  "files": [
    "dist",
    "templates-binary"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "default": "./dist/browser.mjs"
    },
    "./fs-writer": {
      "types": "./dist/fs-writer.d.mts",
      "default": "./dist/fs-writer.mjs"
    },
    "./template-reader": {
      "types": "./dist/template-reader.d.mts",
      "default": "./dist/template-reader.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate-templates": "bun scripts/generate-templates.ts",
    "prebuild": "bun run generate-templates",
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "dev": "tsdown --watch",
    "test": "bun run typecheck:test && bun test",
    "test:watch": "bun test --watch",
    "prelint": "test -f src/templates.generated.ts || bun run generate-templates",
    "lint": "oxlint . && tsc --noEmit",
    "pretypecheck": "test -f src/templates.generated.ts || bun run generate-templates",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "check-deps": "bun scripts/check-deps.ts",
    "check-deps:fix": "bun scripts/check-deps.ts --apply-patch",
    "sync-versions": "bun scripts/sync-template-versions.ts",
    "sync-versions:fix": "bun scripts/sync-template-versions.ts --fix"
  },
  "dependencies": {
    "@better-fullstack/types": "workspace:*",
    "effect": "^3.21.2",
    "handlebars": "^4.7.9",
    "memfs": "4.57.3",
    "pathe": "^2.0.3",
    "ts-morph": "^27.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "fs-extra": "^11.3.5",
    "is-binary-path": "^3.0.0",
    "tinyglobby": "^0.2.17",
    "tsdown": "^0.17.2",
    "typescript": "^5.9.3"
  }
}
