{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.types": "tsc --incremental --noEmit",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "preview": "qwik build preview && vite preview --open",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    {{!-- WORKAROUND: @builder.io/qwik@1.19.2 CLI requires 'ignore' at runtime but doesn't declare it.
         bun doesn't hoist transitive deps like npm, so qwik build crashes with MODULE_NOT_FOUND.
         Remove when Qwik fixes this upstream or when upgrading to Qwik v2. --}}
    "ignore": "^7.0.5",
    {{#if (eq cssFramework "tailwind")}}
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    {{/if}}
    "typescript": "^5",
    "vite": "^8.0.12",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
