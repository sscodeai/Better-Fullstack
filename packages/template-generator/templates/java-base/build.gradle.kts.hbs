plugins {
{{#if isJavaSpringBoot}}
	java
	id("org.springframework.boot") version "4.0.6"
	id("io.spring.dependency-management") version "1.1.7"
{{else if isJavaQuarkus}}
	java
	id("io.quarkus") version "3.35.2"
{{else}}
	java
	application
{{/if}}
}

group = "{{javaGroupId}}"
version = "0.0.1-SNAPSHOT"

{{#if isJavaPlainJava}}
application {
	mainClass = "{{javaPackageName}}.Application"
}

tasks.jar {
	manifest {
		attributes["Main-Class"] = "{{javaPackageName}}.Application"
	}
}
{{/if}}

java {
	toolchain {
		languageVersion = JavaLanguageVersion.of(21)
	}
}

repositories {
	mavenCentral()
}

dependencies {
{{#if (eq email "resend")}}
	implementation("com.resend:resend-java:4.13.0")
{{/if}}
{{#if (eq observability "sentry")}}
	implementation("io.sentry:sentry:8.16.0")
{{/if}}
{{#if (eq caching "upstash-redis")}}
	implementation("redis.clients:jedis:7.5.0")
{{/if}}
{{#if (eq search "meilisearch")}}
	implementation("com.meilisearch.sdk:meilisearch-java:0.14.4")
{{/if}}
{{#if isJavaSpringBoot}}
{{#if hasJavaJpa}}
	implementation("org.springframework.boot:spring-boot-starter-data-jpa")
{{/if}}
{{#if hasJavaSecurity}}
	implementation("org.springframework.boot:spring-boot-starter-security")
{{/if}}
{{#if hasJavaActuator}}
	implementation("org.springframework.boot:spring-boot-starter-actuator")
{{/if}}
{{#if hasJavaValidation}}
	implementation("org.springframework.boot:spring-boot-starter-validation")
{{/if}}
{{#if hasJavaFlyway}}
	implementation("org.springframework.boot:spring-boot-starter-flyway")
{{/if}}
{{#if hasJavaLiquibase}}
	implementation("org.springframework.boot:spring-boot-starter-liquibase")
{{/if}}
{{#if hasJavaSpringdocOpenapi}}
	implementation("org.springdoc:springdoc-openapi-starter-webmvc-ui:3.0.3")
{{/if}}
{{#if hasJavaLombok}}
	compileOnly("org.projectlombok:lombok:1.18.46")
	annotationProcessor("org.projectlombok:lombok:1.18.46")
	testCompileOnly("org.projectlombok:lombok:1.18.46")
	testAnnotationProcessor("org.projectlombok:lombok:1.18.46")
{{/if}}
{{#if hasJavaMapstruct}}
	implementation("org.mapstruct:mapstruct:1.6.3")
	annotationProcessor("org.mapstruct:mapstruct-processor:1.6.3")
	testAnnotationProcessor("org.mapstruct:mapstruct-processor:1.6.3")
{{/if}}
{{#if hasJavaCaffeine}}
	implementation("org.springframework.boot:spring-boot-starter-cache")
	implementation("com.github.ben-manes.caffeine:caffeine")
{{/if}}
{{#if hasJavaResilience4j}}
	implementation("io.github.resilience4j:resilience4j-spring-boot3:2.3.0")
{{/if}}
{{#if hasJavaWebflux}}
	implementation("org.springframework.boot:spring-boot-starter-webflux")
{{/if}}
{{#if hasJavaBatch}}
	implementation("org.springframework.boot:spring-boot-starter-batch")
{{/if}}
{{#if hasJavaKafka}}
	implementation("org.springframework.kafka:spring-kafka")
{{/if}}
{{#if hasJavaMail}}
	implementation("org.springframework.boot:spring-boot-starter-mail")
{{/if}}
{{#if hasJavaDevtools}}
	developmentOnly("org.springframework.boot:spring-boot-devtools")
{{/if}}
{{#if hasJavaMicrometerPrometheus}}
	runtimeOnly("io.micrometer:micrometer-registry-prometheus")
{{/if}}
{{#if hasJavaThymeleaf}}
	implementation("org.springframework.boot:spring-boot-starter-thymeleaf")
{{/if}}
	implementation("org.springframework.boot:spring-boot-starter-webmvc")
{{#if hasJavaJpa}}
	runtimeOnly("com.h2database:h2")
{{/if}}

{{#if hasJavaTests}}
{{#if hasJavaJpa}}
	testImplementation("org.springframework.boot:spring-boot-starter-data-jpa-test")
{{/if}}
{{#if hasJavaSecurity}}
	testImplementation("org.springframework.boot:spring-boot-starter-security-test")
{{/if}}
	testImplementation("org.springframework.boot:spring-boot-starter-webmvc-test")
{{#if hasJavaAssertj}}
	testImplementation("org.assertj:assertj-core:3.27.7")
{{/if}}
{{#if hasJavaRestAssured}}
	testImplementation("io.rest-assured:rest-assured:6.0.0")
{{/if}}
{{#if hasJavaWireMock}}
	testImplementation("org.wiremock:wiremock:3.13.2")
{{/if}}
{{#if hasJavaAwaitility}}
	testImplementation("org.awaitility:awaitility:4.3.0")
{{/if}}
{{#if hasJavaArchunit}}
	testImplementation("com.tngtech.archunit:archunit-junit5:1.4.2")
{{/if}}
{{#if hasJavaJqwik}}
	testImplementation("net.jqwik:jqwik:1.9.3")
{{/if}}
{{#if hasJavaTestcontainers}}
	testImplementation("org.springframework.boot:spring-boot-testcontainers")
	testImplementation("org.testcontainers:testcontainers-junit-jupiter")
{{/if}}
	testRuntimeOnly("org.junit.platform:junit-platform-launcher")
{{/if}}
{{else if isJavaQuarkus}}
	implementation(enforcedPlatform("io.quarkus.platform:quarkus-bom:3.35.2"))
	implementation("io.quarkus:quarkus-rest")
{{#if hasJavaTests}}
	testImplementation("io.quarkus:quarkus-junit5")
{{/if}}
{{else}}
{{#if hasJavaTests}}
	testImplementation(platform("org.junit:junit-bom:5.12.2"))
	testImplementation("org.junit.jupiter:junit-jupiter")
{{#if hasJavaAssertj}}
	testImplementation("org.assertj:assertj-core:3.27.7")
{{/if}}
{{#if hasJavaMockito}}
	testImplementation("org.mockito:mockito-junit-jupiter:5.23.0")
{{/if}}
{{#if hasJavaTestcontainers}}
	testImplementation(platform("org.testcontainers:testcontainers-bom:1.20.4"))
	testImplementation("org.testcontainers:junit-jupiter")
	testImplementation("org.testcontainers:testcontainers")
{{/if}}
{{#if hasJavaRestAssured}}
	testImplementation("io.rest-assured:rest-assured:6.0.0")
{{/if}}
{{#if hasJavaWireMock}}
	testImplementation("org.wiremock:wiremock:3.13.2")
{{/if}}
{{#if hasJavaAwaitility}}
	testImplementation("org.awaitility:awaitility:4.3.0")
{{/if}}
{{#if hasJavaArchunit}}
	testImplementation("com.tngtech.archunit:archunit-junit5:1.4.2")
{{/if}}
{{#if hasJavaJqwik}}
	testImplementation("net.jqwik:jqwik:1.9.3")
{{/if}}
{{/if}}
{{/if}}
}

tasks.withType<Test> {
	useJUnitPlatform()
}
