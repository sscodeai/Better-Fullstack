[workspace]
resolver = "2"
members = [
    "crates/server",
{{#if (eq rustApi "tonic")}}
    "crates/proto",
{{/if}}
{{#if (eq rustFrontend "leptos")}}
    "crates/client",
{{/if}}
{{#if (eq rustFrontend "dioxus")}}
    "crates/dioxus-client",
{{/if}}
{{#if (eq rustCli "clap")}}
    "crates/cli",
{{/if}}
{{#if (eq rustCli "ratatui")}}
    "crates/tui",
{{/if}}
]

[workspace.package]
version = "0.1.0"
edition = "2021"
authors = ["Your Name <your.email@example.com>"]
license = "MIT"
repository = ""

[workspace.dependencies]
# Async runtime
tokio = { version = "1.51", features = ["full"] }

# Serialization
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"

{{#if (eq rustErrorHandling "anyhow-thiserror")}}
# Error handling (anyhow + thiserror)
thiserror = "2.0"
anyhow = "1.0"
{{else if (eq rustErrorHandling "eyre")}}
# Error handling (eyre + color-eyre)
eyre = "0.6"
color-eyre = "0.6"
{{/if}}

{{#if (or (eq rustLogging "tracing") (not (eq rustCli "none")) (not (eq rustFrontend "none")))}}
# Tracing (used by server logging, CLI, TUI, and WASM frontends)
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
{{/if}}
{{#if (eq rustLogging "env-logger")}}
# Logging (env_logger)
log = "0.4"
env_logger = "0.11"
{{/if}}

# Environment variables
dotenvy = "0.15"

{{#if (eq email "resend")}}
# Email delivery
resend-rs = { version = "0.24", default-features = false, features = ["rustls-tls"] }
{{/if}}
{{#if (eq observability "sentry")}}
# Error tracking and performance monitoring
sentry = "0.48.1"
{{/if}}
{{#if (eq caching "upstash-redis")}}
# Upstash Redis via Redis protocol
redis = { version = "1.2.1", features = ["tokio-comp"] }
{{/if}}
{{#if (eq search "meilisearch")}}
# Search
meilisearch-sdk = "0.33.0"
{{/if}}

{{#if (eq rustWebFramework "axum")}}
# Web framework (Axum)
axum = "0.8"
tower = "0.5"
tower-http = { version = "0.6", features = ["cors", "trace"] }
{{/if}}
{{#if (eq rustWebFramework "actix-web")}}
# Web framework (Actix-web)
actix-web = "4"
actix-rt = "2"
actix-cors = "0.7"
{{/if}}
{{#if (eq rustWebFramework "rocket")}}
# Web framework (Rocket)
rocket = { version = "0.5", features = ["json"] }
rocket_cors = "0.6"
{{/if}}

{{#if (eq rustOrm "sqlx")}}
# Database (SQLx)
sqlx = { version = "0.8", features = ["runtime-tokio", "postgres", "sqlite", "mysql", "migrate"] }
{{/if}}
{{#if (eq rustOrm "sea-orm")}}
# Database (SeaORM)
sea-orm = { version = "1.1", features = ["runtime-tokio-rustls", "sqlx-postgres", "sqlx-sqlite", "sqlx-mysql"] }
sea-orm-migration = "1.1"
{{/if}}
{{#if (eq rustOrm "diesel")}}
# Database (Diesel + diesel-async)
diesel = { version = "2.3", features = ["postgres"] }
diesel-async = { version = "0.8", features = ["postgres", "deadpool"] }
{{/if}}

{{#if (eq rustApi "tonic")}}
# gRPC (Tonic)
tonic = "0.12"
tonic-build = "0.12"
prost = "0.13"
{{/if}}
{{#if (eq rustApi "async-graphql")}}
# GraphQL (async-graphql)
async-graphql = "7"
{{#if (eq rustWebFramework "axum")}}
async-graphql-axum = "7"
{{/if}}
{{#if (eq rustWebFramework "actix-web")}}
async-graphql-actix-web = "7"
{{/if}}
{{#if (eq rustWebFramework "rocket")}}
async-graphql-rocket = "7"
{{/if}}
{{/if}}

{{#if (eq rustFrontend "leptos")}}
# Frontend (Leptos)
leptos = "0.7"
leptos_router = "0.7"
leptos_meta = "0.7"
console_error_panic_hook = "0.1"
console_log = "1"
{{#unless (eq rustLogging "env-logger")}}
log = "0.4"
{{/unless}}
wasm-bindgen = "0.2"
wasm-bindgen-futures = "0.4"
web-sys = { version = "0.3", features = ["Window", "Document", "Element", "HtmlElement", "console"] }
{{/if}}
{{#if (eq rustFrontend "dioxus")}}
# Frontend (Dioxus)
dioxus = { version = "0.6", features = ["router"] }
dioxus-router = "0.6"
dioxus-logger = "0.6"
console_error_panic_hook = "0.1"
wasm-bindgen = "0.2"
{{/if}}

{{#if (eq rustCli "clap")}}
# CLI (Clap)
clap = { version = "4", features = ["derive"] }
{{/if}}
{{#if (eq rustCli "ratatui")}}
# TUI (Ratatui)
ratatui = "0.29"
crossterm = "0.28"
tracing-appender = "0.2"
{{/if}}

{{#if (includes rustLibraries "uuid")}}
# UUID generation and parsing
uuid = { version = "1.23.1", features = ["v4", "v7", "serde"] }
{{/if}}
{{#if (includes rustLibraries "chrono")}}
# Date and time
chrono = { version = "0.4.44", features = ["serde"] }
{{/if}}
{{#if (includes rustLibraries "reqwest")}}
# HTTP client
reqwest = { version = "0.13.3", default-features = false, features = ["json", "rustls"] }
{{/if}}
{{#if (includes rustLibraries "config")}}
# Layered configuration
config = "0.15.22"
{{/if}}
{{#if (includes rustLibraries "dashmap")}}
# Concurrent maps
dashmap = "6"
{{/if}}
{{#if (includes rustLibraries "parking-lot")}}
# Synchronization primitives
parking_lot = "0.12"
{{/if}}
{{#if (includes rustLibraries "secrecy")}}
# Secret handling
secrecy = { version = "0.10", features = ["serde"] }
{{/if}}
{{#if (includes rustLibraries "tokio-util")}}
# Tokio utilities
tokio-util = { version = "0.7", features = ["codec", "io", "rt"] }
{{/if}}
{{#if (includes rustLibraries "utoipa")}}
# OpenAPI generation
utoipa = { version = "5", features = ["axum_extras", "chrono", "uuid"] }
{{/if}}
{{#if (includes rustLibraries "validator")}}
# Validation
validator = { version = "0.19", features = ["derive"] }
{{/if}}
{{#if (includes rustLibraries "jsonwebtoken")}}
# JWT
jsonwebtoken = "9"
{{/if}}
{{#if (includes rustLibraries "argon2")}}
# Password hashing
argon2 = "0.5"
{{/if}}
{{#if (includes rustLibraries "tokio-test")}}
# Testing
tokio-test = "0.4"
{{/if}}
{{#if (includes rustLibraries "mockall")}}
# Mocking
mockall = "0.13"
{{/if}}
{{#if (includes rustLibraries "proptest")}}
# Property-based testing
proptest = "1"
{{/if}}
{{#if (includes rustLibraries "insta")}}
# Snapshot testing
insta = { version = "1", features = ["yaml"] }
{{/if}}

{{#if (eq rustCaching "moka")}}
# Caching (Moka)
moka = { version = "0.12", features = ["future"] }
{{/if}}
{{#if (eq rustCaching "redis")}}
# Caching (Redis)
redis = { version = "0.29", features = ["aio", "tokio-comp"] }
{{/if}}

{{#if (eq rustAuth "oauth2")}}
# Auth (OAuth2)
oauth2 = "4.4"
url = "2"
{{/if}}

[profile.dev]
opt-level = 0

[profile.release]
opt-level = 3
lto = true
codegen-units = 1
