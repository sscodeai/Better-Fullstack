[package]
name = "{{projectName}}-server"
version.workspace = true
edition.workspace = true
authors.workspace = true
license.workspace = true

[dependencies]
# Async runtime
tokio.workspace = true

# Serialization
serde.workspace = true
serde_json.workspace = true

{{#if (eq rustErrorHandling "anyhow-thiserror")}}
# Error handling
thiserror.workspace = true
anyhow.workspace = true
{{else if (eq rustErrorHandling "eyre")}}
# Error handling
eyre.workspace = true
color-eyre.workspace = true
{{/if}}

{{#if (eq rustLogging "tracing")}}
# Logging
tracing.workspace = true
tracing-subscriber.workspace = true
{{/if}}
{{#if (eq rustLogging "env-logger")}}
# Logging
log.workspace = true
env_logger.workspace = true
{{/if}}

# Environment
dotenvy.workspace = true

{{#if (eq email "resend")}}
# Email delivery
resend-rs.workspace = true
{{/if}}
{{#if (eq observability "sentry")}}
# Error tracking and performance monitoring
sentry.workspace = true
{{/if}}
{{#if (eq caching "upstash-redis")}}
# Upstash Redis via Redis protocol
redis.workspace = true
{{/if}}
{{#if (eq search "meilisearch")}}
# Search
meilisearch-sdk.workspace = true
{{/if}}

{{#if (eq rustWebFramework "axum")}}
# Web framework
axum.workspace = true
tower.workspace = true
tower-http.workspace = true
{{/if}}
{{#if (eq rustWebFramework "actix-web")}}
# Web framework
actix-web.workspace = true
actix-rt.workspace = true
actix-cors.workspace = true
{{/if}}
{{#if (eq rustWebFramework "rocket")}}
# Web framework
rocket.workspace = true
rocket_cors.workspace = true
{{/if}}

{{#if (eq rustOrm "sqlx")}}
# Database
sqlx.workspace = true
{{/if}}
{{#if (eq rustOrm "sea-orm")}}
# Database
sea-orm.workspace = true
{{/if}}
{{#if (eq rustOrm "diesel")}}
# Database
diesel.workspace = true
diesel-async.workspace = true
{{/if}}

{{#if (eq rustApi "tonic")}}
# gRPC
tonic.workspace = true
prost.workspace = true
{{projectName}}-proto = { path = "../proto" }
tokio-stream = "0.1"
{{/if}}
{{#if (eq rustApi "async-graphql")}}
# GraphQL
async-graphql.workspace = true
{{#if (eq rustWebFramework "axum")}}
async-graphql-axum.workspace = true
{{/if}}
{{#if (eq rustWebFramework "actix-web")}}
async-graphql-actix-web.workspace = true
{{/if}}
{{#if (eq rustWebFramework "rocket")}}
async-graphql-rocket.workspace = true
{{/if}}
{{/if}}

{{#if (includes rustLibraries "validator")}}
validator.workspace = true
{{/if}}
{{#if (includes rustLibraries "jsonwebtoken")}}
jsonwebtoken.workspace = true
{{/if}}
{{#if (includes rustLibraries "argon2")}}
argon2.workspace = true
{{/if}}
{{#if (eq rustCli "clap")}}

# CLI
clap.workspace = true
{{/if}}

{{#if (includes rustLibraries "uuid")}}
uuid.workspace = true
{{/if}}
{{#if (includes rustLibraries "chrono")}}
chrono.workspace = true
{{/if}}
{{#if (includes rustLibraries "reqwest")}}
reqwest.workspace = true
{{/if}}
{{#if (includes rustLibraries "config")}}
config.workspace = true
{{/if}}
{{#if (includes rustLibraries "dashmap")}}
dashmap.workspace = true
{{/if}}
{{#if (includes rustLibraries "parking-lot")}}
parking_lot.workspace = true
{{/if}}
{{#if (includes rustLibraries "secrecy")}}
secrecy.workspace = true
{{/if}}
{{#if (includes rustLibraries "tokio-util")}}
tokio-util.workspace = true
{{/if}}
{{#if (includes rustLibraries "utoipa")}}
utoipa.workspace = true
{{/if}}
{{#if (eq rustCaching "moka")}}
# Caching
moka.workspace = true
{{/if}}
{{#if (eq rustCaching "redis")}}
# Caching
redis.workspace = true
{{/if}}

{{#if (eq rustAuth "oauth2")}}
# Auth
oauth2.workspace = true
url.workspace = true
{{/if}}

[[bin]]
name = "server"
path = "src/main.rs"

{{#if (or (or (includes rustLibraries "tokio-test") (includes rustLibraries "mockall")) (or (includes rustLibraries "proptest") (includes rustLibraries "insta")))}}
[dev-dependencies]
{{#if (includes rustLibraries "tokio-test")}}
tokio-test.workspace = true
{{/if}}
{{#if (includes rustLibraries "mockall")}}
mockall.workspace = true
{{/if}}
{{#if (includes rustLibraries "proptest")}}
proptest.workspace = true
{{/if}}
{{#if (includes rustLibraries "insta")}}
insta.workspace = true
{{/if}}
{{/if}}
