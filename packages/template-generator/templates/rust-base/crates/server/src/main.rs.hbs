#[get("/health")]
async fn health(state: &rocket::State<AppState>) -> Json<HealthResponse> {
    let db_status = if state.db.acquire().await.is_ok() {
        "connected"
    } else {
        "disconnected"
    };
    Json(HealthResponse {
        status: "ok",
        message: "Server is running",
        database: db_status,
    })
}
{{else if (eq rustOrm "diesel")}}
pub struct AppState {
    pub pool: Pool<AsyncPgConnection>,
}

#[get("/health")]
