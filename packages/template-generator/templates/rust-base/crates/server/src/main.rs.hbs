        .route("/health", get(health))
        .layer(CorsLayer::permissive());
{{/if}}
{{/if}}

    // Get host and port from environment
    let host = std::env::var("HOST").unwrap_or_else(|_| "127.0.0.1".to_string());
    let port = std::env::var("PORT").unwrap_or_else(|_| "3000".to_string());
    let addr = format!("{}:{}", host, port);

{{#if (eq rustLogging "tracing")}}    tracing::info!("Starting HTTP server at http://{}", addr);{{else if (eq rustLogging "env-logger")}}    log::info!("Starting HTTP server at http://{}", addr);{{else}}    println!("Starting HTTP server at http://{}", addr);{{/if}}

{{#if (eq rustApi "tonic")}}
    // Start gRPC server on a separate port
    let grpc_port = std::env::var("GRPC_PORT").unwrap_or_else(|_| "50051".to_string());
    let grpc_addr = format!("{}:{}", host, grpc_port).parse()?;

{{#if (eq rustLogging "tracing")}}    tracing::info!("Starting gRPC server at {}", grpc_addr);{{else if (eq rustLogging "env-logger")}}    log::info!("Starting gRPC server at {}", grpc_addr);{{else}}    println!("Starting gRPC server at {}", grpc_addr);{{/if}}

    let grpc_server = tonic::transport::Server::builder()
        .add_service(grpc::create_grpc_server())
        .serve(grpc_addr);

    // Start HTTP server
    let listener = tokio::net::TcpListener::bind(&addr).await?;
    let http_server = axum::serve(listener, app);

    // Run both servers concurrently
    tokio::select! {
        result = http_server => {
            if let Err(e) = result {
{{#if (eq rustLogging "tracing")}}                tracing::error!("HTTP server error: {}", e);{{else if (eq rustLogging "env-logger")}}                log::error!("HTTP server error: {}", e);{{else}}                eprintln!("HTTP server error: {}", e);{{/if}}
            }
        }
        result = grpc_server => {
            if let Err(e) = result {
{{#if (eq rustLogging "tracing")}}                tracing::error!("gRPC server error: {}", e);{{else if (eq rustLogging "env-logger")}}                log::error!("gRPC server error: {}", e);{{else}}                eprintln!("gRPC server error: {}", e);{{/if}}
            }
        }
    }
{{else}}
    // Start server
    let listener = tokio::net::TcpListener::bind(&addr).await?;
    axum::serve(listener, app).await?;
{{/if}}

    Ok(())
}
