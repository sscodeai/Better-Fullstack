{{/if}}
{{#if (eq elixirObservability "prom_ex")}}
      {:prom_ex, "~> 1.11"},
{{/if}}
{{#if (eq elixirTesting "mox")}}
      {:mox, "~> 1.2", only: :test},
{{/if}}
{{#if (eq elixirTesting "bypass")}}
      {:bypass, "~> 2.1", only: :test},
{{/if}}
{{#if (eq elixirTesting "wallaby")}}
      {:wallaby, "~> 0.30", only: :test},
{{/if}}
{{#if (eq elixirQuality "credo")}}
      {:credo, "~> 1.7", only: [:dev, :test], runtime: false},
{{/if}}
{{#if (eq elixirQuality "dialyxir")}}
      {:dialyxir, "~> 1.4", only: [:dev], runtime: false},
{{/if}}
{{#if (eq elixirQuality "sobelow")}}
      {:sobelow, "~> 0.14", only: [:dev, :test], runtime: false},
{{/if}}
      {:plug_cowboy, "~> 2.7"}
    ]
  end

  defp aliases do
    [
{{#if (ne elixirOrm "none")}}
      setup: ["deps.get", "ecto.setup"],
      "ecto.setup": ["ecto.create", "ecto.migrate", "run priv/repo/seeds.exs"],
      "ecto.reset": ["ecto.drop", "ecto.setup"],
      test: ["ecto.create --quiet", "ecto.migrate --quiet", "test"]
{{else}}
      setup: ["deps.get"],
      test: ["test"]
{{/if}}
    ]
  end
end
