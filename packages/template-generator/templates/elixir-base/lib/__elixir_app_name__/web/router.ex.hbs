defmodule {{elixirModuleName}}Web.Router do
  use Phoenix.Router

  pipeline :browser do
    plug :accepts, ["html"]
  end

  pipeline :api do
    plug :accepts, ["json"]
  end

  scope "/", {{elixirModuleName}}Web do
    pipe_through :browser

    get "/", PageController, :home
  end

  scope "/api", {{elixirModuleName}}Web do
    pipe_through :api

    get "/health", HealthController, :show
  end
end
