import type { Context } from "../context{{#if (eq backend "adonisjs")}}.js{{/if}}";

export function createRouter({{#if (isBetterAuth auth)}}ctx{{else}}_ctx{{/if}}: Context) {
  return {
    healthCheck: async () => {
      return {
        status: 200 as const,
        body: "OK" as const,
      };
    },
{{#if (isBetterAuth auth)}}
    privateData: async () => {
      if (!ctx.session) {
        return {
          status: 401 as const,
          body: {
            message: "Authentication required",
          },
        };
      }
      return {
        status: 200 as const,
        body: {
          message: "This is private",
          user: ctx.session.user,
        },
      };
    },
{{/if}}
  };
}

export type AppRouter = ReturnType<typeof createRouter>;
