import { QueryClient } from "@tanstack/react-query";
import { initClient, tsRestFetchApi } from "@ts-rest/core";
import { initTsrReactQuery } from "@ts-rest/react-query/v5";
import { contract } from "@{{projectName}}/api/index";
import { env } from "@{{projectName}}/env/web";

export const queryClient = new QueryClient({
	defaultOptions: {
		queries: {
			retry: 2,
			staleTime: 1000 * 60,
		},
	},
});

const clientArgs = {
	baseUrl: {{#if (includes frontend "next")}}`${env.NEXT_PUBLIC_SERVER_URL}/rest`{{else}}`${env.VITE_SERVER_URL}/rest`{{/if}},
	baseHeaders: {},
{{#if (eq auth "better-auth")}}
	credentials: "include" as const,
{{/if}}
	api: tsRestFetchApi,
};

const client = initClient(contract, clientArgs);

export const tsr = initTsrReactQuery(contract, clientArgs);
